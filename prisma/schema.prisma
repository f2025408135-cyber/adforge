generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  image        String?
  passwordHash String?
  provider     String   @default("credentials")
  role         String   @default("user")
  plan         String   @default("free")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaigns       Campaign[]
  brandKits       BrandKit[]
  apiUsage        ApiUsage[]
  teamMemberships TeamMember[]
}

model Campaign {
  id             String   @id @default(cuid())
  userId         String
  productName    String
  productDesc    String
  tone           String   @default("professional")
  audience       String?
  platforms      String   @default("instagram,facebook")
  provider       String   @default("gemini")
  headline       String?
  tagline        String?
  adCopy         String?
  callToAction   String?
  targetAudience String?
  keyBenefits    String?
  platformVersions String?
  status         String   @default("completed")
  isFavorite     Boolean  @default(false)
  variants       String?
  tags           String?
  rating         Int?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exports  Export[]
  versions CampaignVersion[]

  @@index([userId])
  @@index([createdAt])
}

model CampaignVersion {
  id             String   @id @default(cuid())
  campaignId     String
  version        Int
  headline       String?
  tagline        String?
  adCopy         String?
  callToAction   String?
  targetAudience String?
  keyBenefits    String?
  platformVersions String?
  changeSummary  String?
  createdAt      DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model BrandKit {
  id            String   @id @default(cuid())
  userId        String
  name          String
  brandName     String
  brandVoice    String
  primaryColor  String?
  secondaryColor String?
  logo          String?
  guidelines    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      String   @default("viewer")
  invitedAt DateTime @default(now())
  acceptedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Export {
  id         String   @id @default(cuid())
  campaignId String
  format     String
  filePath   String?
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model ApiUsage {
  id         String   @id @default(cuid())
  userId     String
  provider   String
  endpoint   String
  tokensUsed Int      @default(0)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Template {
  id            String   @id @default(cuid())
  name          String
  description   String
  category      String
  promptTemplate String
  tone          String   @default("professional")
  isPublic      Boolean  @default(true)
  usageCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
